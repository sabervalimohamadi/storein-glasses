# ─────────────────────────────────────────────────────────────────────────────
# Backend (.env) — copy to /var/www/storein/storein/.env
# Replace YOUR_VPS_IP and YOUR_SECRET values
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3001
APP_NAME=storein

# ── MongoDB (local) ───────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/storein

# ── Redis (local) ─────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=300

# ── JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_RUN_COMMAND_ABOVE
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_VALUE
JWT_REFRESH_EXPIRES_IN=30d

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_EXPIRES_IN=120
OTP_LENGTH=6

# ── Uploads ───────────────────────────────────────────────────────────────────
UPLOAD_DEST=./uploads
UPLOAD_MAX_FILE_SIZE=5242880
UPLOAD_BASE_URL=http://YOUR_VPS_IP

# ── Payment ───────────────────────────────────────────────────────────────────
PAYMENT_GATEWAY=mock
ZARINPAL_MERCHANT_ID=
PAYMENT_CALLBACK_URL=http://YOUR_VPS_IP/api/v1/payments/verify

# ── SMS ───────────────────────────────────────────────────────────────────────
SMS_PROVIDER=mock
KAVENEGAR_API_KEY=
KAVENEGAR_SENDER=
KAVENEGAR_OTP_TEMPLATE=storein-otp

# ── CORS (frontend + admin origins) ──────────────────────────────────────────
ALLOWED_ORIGINS=http://YOUR_VPS_IP,http://YOUR_VPS_IP:4000

# ── Cookie (HTTP, no SSL yet) ─────────────────────────────────────────────────
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false
