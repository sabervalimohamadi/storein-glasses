# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
APP_NAME=storein

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/storein

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=300

# ── JWT — توسط این دستور بساز: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_RUN_COMMAND_ABOVE
JWT_EXPIRES_IN=30d
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_VALUE
JWT_REFRESH_EXPIRES_IN=30d

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_EXPIRES_IN=120
OTP_LENGTH=6

# ── Upload ────────────────────────────────────────────────────────────────────
UPLOAD_DEST=./uploads
UPLOAD_MAX_FILE_SIZE=5242880
UPLOAD_BASE_URL=http://45.94.215.8

# ── CORS (IP-based تا قبل از دامنه) ──────────────────────────────────────────
ALLOWED_ORIGINS=http://45.94.215.8,http://45.94.215.8:4000
# وقتی دامنه خریدی:
# ALLOWED_ORIGINS=https://storein.ir,https://admin.storein.ir

# ── Cookie ────────────────────────────────────────────────────────────────────
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false
# وقتی SSL آمد: COOKIE_SECURE=true

# ── Payment ───────────────────────────────────────────────────────────────────
PAYMENT_GATEWAY=mock
ZARINPAL_MERCHANT_ID=
PAYMENT_CALLBACK_URL=http://45.94.215.8/api/v1/payments/verify

# ── SMS ───────────────────────────────────────────────────────────────────────
SMS_PROVIDER=mock
KAVENEGAR_API_KEY=
KAVENEGAR_SENDER=
KAVENEGAR_OTP_TEMPLATE=storein-otp
