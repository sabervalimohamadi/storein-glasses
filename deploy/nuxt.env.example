# ─────────────────────────────────────────────────────────────────────────────
# Nuxt (.env) — copy to /var/www/storein/storein-nuxt/.env
# Replace YOUR_VPS_IP
# ─────────────────────────────────────────────────────────────────────────────

# Internal URL for SSR server-side API calls (backend on same VPS)
API_INTERNAL_URL=http://localhost:3001

# Public site URL — used for og:image absolute URLs and sitemap
NUXT_PUBLIC_SITE_URL=http://YOUR_VPS_IP
