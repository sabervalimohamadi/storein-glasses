# ─────────────────────────────────────────────────────────────────────────────
# storein-admin — Build-time Environment Variables
#
# IMPORTANT: Vite bakes these into the JS bundle at BUILD time.
# On Railway, set them as environment variables on the storein-admin service.
# ─────────────────────────────────────────────────────────────────────────────

# Full URL to the backend API (no trailing slash)
VITE_API_BASE_URL=https://your-backend.up.railway.app/api/v1

VITE_APP_NAME=Storein Admin
