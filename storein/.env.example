# ─────────────────────────────────────────────────────────────────────────────
# Storein Backend — Environment Variables
# Copy this file to .env and fill in the values.
#
# On Railway:
#   • Add the MongoDB plugin → set MONGODB_URI = ${{MongoDB.MONGODB_URL}}
#   • Add the Redis plugin   → set REDIS_HOST  = ${{Redis.REDIS_HOST}}
#                                  REDIS_PORT  = ${{Redis.REDIS_PORT}}
#                                  REDIS_PASSWORD = ${{Redis.REDIS_PASSWORD}}
#   • All other vars must be set manually in the Railway service settings.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_NAME=storein

# ── Database (MongoDB) ────────────────────────────────────────────────────────
# Railway: ${{MongoDB.MONGODB_URL}}
MONGODB_URI=mongodb://localhost:27017/storein

# ── Cache (Redis) ─────────────────────────────────────────────────────────────
# Railway: ${{Redis.REDIS_HOST}} / ${{Redis.REDIS_PORT}} / ${{Redis.REDIS_PASSWORD}}
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=300

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_RANDOM_BYTES_HEX
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_64_RANDOM_BYTES_HEX
JWT_REFRESH_EXPIRES_IN=30d

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_EXPIRES_IN=120
OTP_LENGTH=6

# ── File Uploads ──────────────────────────────────────────────────────────────
# Mount a Railway Volume at /app/uploads to persist files across deploys.
UPLOAD_DEST=./uploads
UPLOAD_MAX_FILE_SIZE=5242880
# Set to your Railway public domain after first deploy:
UPLOAD_BASE_URL=https://your-backend.up.railway.app

# ── Payment Gateway ───────────────────────────────────────────────────────────
# mock (no real payments) | zarinpal
PAYMENT_GATEWAY=mock
ZARINPAL_MERCHANT_ID=
# Set to: https://your-backend.up.railway.app/api/v1/payments/verify
PAYMENT_CALLBACK_URL=https://your-backend.up.railway.app/api/v1/payments/verify

# ── SMS Provider ──────────────────────────────────────────────────────────────
# mock (logs OTP to console) | kavenegar
SMS_PROVIDER=mock
KAVENEGAR_API_KEY=
KAVENEGAR_SENDER=
KAVENEGAR_OTP_TEMPLATE=storein-otp

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-front.up.railway.app,https://your-admin.up.railway.app

# ── Cookie (cross-origin Railway deployments) ─────────────────────────────────
# Set these explicitly on Railway if NODE_ENV is not recognised as 'production'.
# SameSite=none + Secure=true are required for cross-subdomain cookie sending.
COOKIE_SAME_SITE=none
COOKIE_SECURE=true
