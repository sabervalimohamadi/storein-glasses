# ─────────────────────────────────────────────────────────────────────────────
# storein-front — Build-time Environment Variables
#
# IMPORTANT: Vite bakes these into the JS bundle at BUILD time.
# On Railway, set them as environment variables on the storein-front service.
# ─────────────────────────────────────────────────────────────────────────────

# ── API URL ──────────────────────────────────────────────────────────────────
# PRODUCTION (Railway with proxy server):
#   Leave VITE_API_BASE_URL UNSET. The proxy server in server.js forwards
#   all /api/* requests to the backend internally — cookies are first-party.
#
# LOCAL DEV (npm run dev):
#   Also leave UNSET. vite.config.js proxy forwards /api/v1/* to localhost:3001.
#
# LOCAL PREVIEW (npm run build && npm run start):
#   Set API_INTERNAL_URL (runtime, not build-time) to http://localhost:3001.
#   No need to set VITE_API_BASE_URL.
#
# VITE_API_BASE_URL=https://your-backend.up.railway.app/api/v1

# ── Runtime env vars for server.js (NOT baked into the bundle) ───────────────
# Set these on Railway for the storein-front service:
#
#   API_INTERNAL_URL=http://<backend-service-name>.railway.internal:3000
#
# Find the correct hostname in Railway dashboard:
#   Project → storein (backend service) → Settings → Networking → Private Networking
#   The hostname shown there is "<service-name>.railway.internal"

VITE_APP_NAME=Storein
VITE_APP_VERSION=1.0.0
